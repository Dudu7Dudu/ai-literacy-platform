generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  name         String?
  role         String        @default("student")
  createdAt    DateTime      @default(now())
  progress     Progress[]
  quizAttempts QuizAttempt[]
}

model Module {
  id          String     @id @default(uuid())
  title       String
  description String
  orderIndex  Int
  createdAt   DateTime   @default(now())
  lessons     Lesson[]
  progress    Progress[]
}

model Lesson {
  id         String @id @default(uuid())
  title      String
  content    String
  orderIndex Int
  moduleId   String
  module     Module @relation(fields: [moduleId], references: [id])
  quizzes    Quiz[]
}

model Progress {
  id        String  @id @default(uuid())
  completed Boolean @default(false)
  userId    String
  moduleId  String
  module    Module  @relation(fields: [moduleId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@unique([userId, moduleId])
}

model Quiz {
  id        String        @id @default(uuid())
  title     String
  lessonId  String
  questions Question[]
  lesson    Lesson        @relation(fields: [lessonId], references: [id])
  attempts  QuizAttempt[]
}

model Question {
  id   String @id @default(uuid())
  text String

  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id])

  answers Answer[]

  incomingBranches Answer[] @relation("QuestionBranch")
}

model Answer {
  id String @id @default(uuid())

  text String

  isCorrect Boolean

  questionId String
  question   Question @relation(fields: [questionId], references: [id])

  nextQuestionId String?
  nextQuestion   Question? @relation("QuestionBranch", fields: [nextQuestionId], references: [id])
}

model QuizAttempt {
  id          String    @id @default(uuid())
  userId      String
  quizId      String
  score       Int
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  quiz        Quiz      @relation(fields: [quizId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}
